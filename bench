#!/bin/bash
# ./bench <push_swap_path> <size> [algorithm] [runs]
# Algorithms: simple, medium, complex, adaptive, compare
# If no algorithm is specified, push_swap decides internally.

set -e

# --------------------------
# Configuration
# --------------------------
VENV_DIR="./pushswap_env"
SCRIPT="./src/benchmark.py"
REQ_FILE="requirements.txt"

# --------------------------
# Help / Usage
# --------------------------
# --------------------------
# Help / Usage
# --------------------------
if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
    echo "Usage: ./bench <push_swap_path> [size] [algorithm] [runs]"
    echo ""
    echo "Arguments / Options:"
    echo "  <push_swap_path>   Path to your push_swap executable"
    echo "  [size]             Number of integers in the list (integer > 1)"
    echo "  [algorithm]        Optional: simple | medium | complex | adaptive | compare"
    echo "                     If omitted, the project can choose the algorithm internally"
    echo "  [runs]             Optional: number of runs per algorithm (default: 200)"
    echo "  clean              Remove all data CSVs and plots"
    echo ""
    echo "Examples:"
    echo "  ./bench ./push_swap 10               # Benchmark default algorithm to sort 10 numbers. Simulate 200 runs"
    echo "  ./bench ./push_swap 50 simple        # Benchmark 'simple' algorithm to sort 50 numbers. Simulate 50 runs"
    echo "  ./bench ./push_swap 20 medium 100    # Benchmark 'medium' algorithm to sort 20 numbers. Simulate 100 runs"
    echo "  ./bench ./push_swap compare 50       # Compare all algorithms  to sort 50 numbers. 200 runs"
    echo "  ./bench clean                         # Remove all data and plots"
    exit 0
fi

# --------------------------
# Check Python3
# --------------------------
if ! command -v python3 &> /dev/null; then
    echo "Python3 is required."
    exit 1
fi

# --------------------------
# Create venv if missing
# --------------------------
if [ ! -d "$VENV_DIR" ]; then
    echo "Creating isolated Python environment..."
    python3 -m venv "$VENV_DIR"
fi

# --------------------------
# Create requirements.txt if missing
# --------------------------
if [ ! -f "$REQ_FILE" ]; then
    echo "Creating $REQ_FILE with required packages..."
    cat <<EOL > "$REQ_FILE"
matplotlib>=3.5
pandas>=1.5
EOL
fi

# --------------------------
# Install dependencies inside venv only if missing
# --------------------------
echo "Checking dependencies in venv..."
if ! "$VENV_DIR/bin/python" -c "import matplotlib, pandas" &> /dev/null; then
    echo "Installing missing packages in venv..."
    "$VENV_DIR/bin/pip" install --upgrade pip
    "$VENV_DIR/bin/pip" install -r "$REQ_FILE"
else
    echo "All dependencies already installed."
fi

# --------------------------
# Run the Python benchmark script using venv Python
# --------------------------
"$VENV_DIR/bin/python" "$SCRIPT" "$@"